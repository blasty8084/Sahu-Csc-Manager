{
  "name": "@workspace/api-server",
  "version": "4.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "echo 'API is managed by the API Server workflow (port 8080). To rebuild: run Build Production. To start: run API Server.'",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "seed": "node ./build.mjs && node --enable-source-maps ./dist/scripts/seed.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "loadtest": "tsx src/scripts/loadtest.ts",
    "loadtest:phase2": "tsx src/scripts/loadtest-phase2.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/instrumentation": "^0.220.0",
    "@opentelemetry/sdk-trace-base": "^2.9.0",
    "@sentry/node": "^10.64.0",
    "@types/multer": "^2.1.0",
    "@types/node-cron": "^3.0.11",
    "@upstash/redis": "^1.38.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.2",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^3.6.0",
    "drizzle-orm": "catalog:",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "geoip-lite": "^2.0.3",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "multer": "^2.2.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "rate-limit-redis": "^5.0.0",
    "uuid": "^14.0.0",
    "web-push": "^3.6.7",
    "xss": "^1.0.15",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/autocannon": "^7.12.7",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/hpp": "^0.2.7",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/uuid": "^11.0.0",
    "@types/web-push": "^3.6.4",
    "autocannon": "^8.0.0",
    "esbuild": "^0.28.1",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "tsx": "catalog:",
