# ─────────────────────────────────────────
#  SAHU CSC — Environment Variables
#  Copy to .env and fill in your values.
#  🔒 = store in Replit Secrets tab, not Env Vars
# ─────────────────────────────────────────


# ── Database ──────────────────────────────
# 🔒 Your Neon PostgreSQL connection string (get from neon.tech dashboard)
NEON_DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Max DB connections in the pool (Neon free tier supports up to 100)
DB_POOL_MAX=10


# ── Session ───────────────────────────────
# 🔒 Secret key for signing session cookies — any long random string
# Generate: openssl rand -base64 48
SESSION_SECRET=your-long-random-secret-here


# ── Admin Accounts ────────────────────────
# 🔒 Passwords for the default admin and operator accounts (created by Seed Database workflow)
ADMIN_PASSWORD=your-admin-password
OPERATOR_PASSWORD=your-operator-password


# ── Email / SMTP ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_FROM_EMAIL=SAHU CSC Support <your-email@gmail.com>

# 🔒 Gmail App Password (not your login password)
# Get from: Google Account → Security → 2-Step Verification → App Passwords
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx


# ── Push Notifications ────────────────────
# Must be in mailto: format — required by the Web Push standard
VAPID_EMAIL=mailto:your-email@gmail.com

# 🔒 VAPID private key — auto-generated at first boot, but set this in production
# so push subscriptions survive re-deploys (rotating it logs everyone out of push)
VAPID_PRIVATE_KEY=


# ── Frontend ──────────────────────────────
PORT=5000
BASE_PATH=/


# ── Cache ─────────────────────────────────
# memory = single-server default | redis = Upstash (for multi-instance)
CACHE_BACKEND=memory

# Required only when CACHE_BACKEND=redis
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=   # 🔒


# ── Background Jobs (optional) ────────────
# 🔒 Upstash Redis TCP URL — enables the Worker Server (BullMQ)
# Must be TCP (rediss://...), not the REST URL above
# REDIS_URL=rediss://default:password@host:port


# ── Security Keys (optional, auto-generated) ──
# Set these in production so encrypted data survives database resets.
# 🔒 AES-256 key for encrypting sensitive fields (address, TOTP secret, etc.)
# ENCRYPTION_KEY=
# 🔒 JWT signing secret
# JWT_SECRET=


# ── Seed Data Defaults ────────────────────
# Default values written to the database by the Seed Database workflow.
# Change anytime from Admin → Settings after seeding.
ADMIN_MOBILE=9876543210
OPERATOR_EMAIL=operator@sahucsc.in
OPERATOR_MOBILE=9876543211
BUSINESS_NAME=SAHU CSC Center
BUSINESS_ADDRESS=Main Road, Bargarh, Odisha 768028


# ── Optional Features ─────────────────────
# 🔒 Sentry error tracking (get DSN from sentry.io)
# SENTRY_DSN=
# VITE_SENTRY_DSN=

# 🔒 MaxMind license key for weekly GeoIP updates (free at maxmind.com)
# MAXMIND_LICENSE_KEY=

# Allow access from outside India (set true when testing via VPN)
# ALLOW_NON_INDIA=false

# Log level: trace | debug | info | warn | error  (default: info)
# LOG_LEVEL=info


# ── Do NOT set these manually ─────────────
# Replit injects these automatically — setting them causes conflicts.
#
# DATABASE_URL   — Replit-managed PostgreSQL (fallback if NEON_DATABASE_URL is absent)
# PGHOST / PGPORT / PGUSER / PGPASSWORD / PGDATABASE
# REPLIT_DEV_DOMAIN / REPLIT_DOMAINS / REPL_ID
