modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["bash", "scripts/start-prod.sh"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && pnpm --filter @workspace/api-server run build && BASE_PATH=/ pnpm --filter @workspace/sahu-csc run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SAHU CSC"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Worker Server"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 NODE_ENV=development pnpm --filter @workspace/api-server run build && PORT=8080 node --enable-source-maps artifacts/api-server/dist/index.mjs"

[[workflows.workflow]]
name = "SAHU CSC"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/sahu-csc run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Seed Database"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 NODE_ENV=development pnpm --filter @workspace/api-server exec tsx src/scripts/seed.ts"

[[workflows.workflow]]
name = "Typecheck"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --if-present run typecheck"

[[workflows.workflow]]
name = "Build Production"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm run typecheck:libs && pnpm --filter @workspace/api-server run build && PORT=5000 BASE_PATH=/ pnpm --filter @workspace/sahu-csc run build"

[[workflows.workflow]]
name = "Production Preview"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 2>/dev/null; sleep 1; pnpm run typecheck:libs && pnpm --filter @workspace/api-server run build && PORT=5000 BASE_PATH=/ pnpm --filter @workspace/sahu-csc run build && PORT=5000 BASE_PATH=/ pnpm --filter @workspace/sahu-csc run serve"
waitForPort = 5000

# Override the platform-auto-generated artifact workflow with a no-op stub
# so it never conflicts with the real "API Server" workflow on port 8080.
[[workflows.workflow]]
name = "artifacts/api-server: API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo 'Use the API Server workflow to run the API on port 8080. This stub prevents the platform-generated duplicate from conflicting.'"

# Override the platform-auto-generated artifact workflow with a no-op stub
# so it never conflicts with the real "SAHU CSC" workflow on port 5000.
[[workflows.workflow]]
name = "artifacts/sahu-csc: web"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo 'Use the SAHU CSC workflow to run the frontend on port 5000. This stub prevents the platform-generated duplicate from conflicting.'"

[[workflows.workflow]]
name = "Worker Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "[ -z \"$REDIS_URL\" ] && echo 'REDIS_URL not set — worker server skipped' && exit 0; PORT=8081 pnpm --filter @workspace/worker-server run build && PORT=8081 node --enable-source-maps artifacts/worker-server/dist/index.mjs"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[[ports]]
localPort = 5000
externalPort = 80

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "5000"
BASE_PATH = "/"
VAPID_EMAIL = "mailto:sahuuttam690@gmail.com"
API_PORT = "8080"
SMTP_FROM_EMAIL = "SAHU CSC Support <sahuuttam690@gmail.com>"
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = "587"
SMTP_USER = "sahuuttam690@gmail.com"
