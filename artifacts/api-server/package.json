{
  "name": "@workspace/api-server",
  "version": "3.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && (test -f ./dist/index.mjs || pnpm run build) && fuser -k 8080/tcp 2>/dev/null; sleep 2; pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "seed": "node ./build.mjs && node --enable-source-maps ./dist/scripts/seed.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
