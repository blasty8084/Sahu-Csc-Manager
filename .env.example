# ============================================================
# SAHU CSC — Environment Variables & Secrets Reference
# Version 4.9.0 · https://github.com/your-repo/sahu-csc
# ============================================================
#
# HOW TO USE THIS FILE
# --------------------
# 1. Copy this file to .env  (never commit .env to git)
# 2. Fill in every value marked  <REQUIRED>
# 3. Review optional values and enable the ones you need
#
# On Replit:
#   • Secrets (🔒 tab)  → SESSION_SECRET, passwords, API keys
#   • Env Vars tab → Shared → everything else
#
# The app reads process.env at runtime — there is no dotenv
# loader in production.  This file is documentation only.
# ============================================================


# ============================================================
# DATABASE
# ============================================================

# Primary database — user-owned Neon PostgreSQL account.
# lib/db reads this first; falls back to DATABASE_URL if absent.
# Get from: Neon dashboard → your project → Connection string
# Use the POOLED connection string for production.
# Store as a Replit Secret (🔒), not a plain env var.
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Fallback — auto-injected by Replit's managed PostgreSQL.
# Do NOT set this manually; Replit owns it.
# DATABASE_URL=postgresql://...  ← injected automatically

# Max simultaneous pg pool connections.
# Replit free-tier PostgreSQL limit: ~20 shared across all repls.
# Neon free-tier: 100 concurrent connections.
DB_POOL_MAX=10


# ============================================================
# SESSION  (🔒 Secret)
# ============================================================

# Signs and verifies every HTTP session cookie.
# Changing this instantly logs out all active users.
# Generate: openssl rand -base64 48
SESSION_SECRET=<REQUIRED: 32+ char random string>


# ============================================================
# SEED ACCOUNTS  (🔒 Secrets — used only by Seed Database workflow)
# ============================================================

# Password for the default `admin` account.
# Policy: 8+ chars, uppercase, lowercase, number.
# Can be changed from Profile page after seeding.
ADMIN_PASSWORD=<REQUIRED: strong password>

# Password for the default `operator` account.
# Same policy as ADMIN_PASSWORD.
OPERATOR_PASSWORD=<REQUIRED: strong password>


# ============================================================
# EMAIL / SMTP  (SMTP_PASSWORD is a 🔒 Secret; the rest are env vars)
# ============================================================

# SMTP server hostname.
SMTP_HOST=smtp.gmail.com

# SMTP port. 587 = STARTTLS (recommended). 465 = implicit SSL.
SMTP_PORT=587

# SMTP login username (your full Gmail address).
SMTP_USER=your-email@gmail.com

# "From" display name and address in outgoing emails.
# Format: Display Name <email@example.com>
SMTP_FROM_EMAIL=SAHU CSC Support <your-email@gmail.com>

# Gmail App Password — NOT your Gmail account password.
# Generate: Google Account → Security → 2-Step Verification → App Passwords
# Store as a Replit Secret (🔒).
SMTP_PASSWORD=<REQUIRED for email/OTP: 16-char Gmail app password>

# Legacy alias — accepted in addition to SMTP_PASSWORD.
# SMTP_PASS=


# ============================================================
# PUSH NOTIFICATIONS — VAPID
# ============================================================

# Contact email sent to browser push services (required by spec).
# Must use mailto: format.
VAPID_EMAIL=mailto:your-email@gmail.com

# VAPID public key — auto-generated at first boot and saved in DB.
# Copy the generated value here for stability across restarts.
# Leave blank to let the server generate one.
VAPID_PUBLIC_KEY=

# VAPID private key — auto-generated at first boot and saved in DB.
# SET THIS EXPLICITLY IN PRODUCTION — rotating it invalidates all
# existing push subscriptions (users must re-subscribe).
# Store as a Replit Secret (🔒).
VAPID_PRIVATE_KEY=


# ============================================================
# FRONTEND SERVER
# ============================================================

# Port the Vite dev server / static serve.mjs listens on.
# Must match the Replit preview port.
PORT=5000

# URL base path for the frontend build.
# Leave as / for all standard Replit deployments.
BASE_PATH=/


# ============================================================
# CACHE BACKEND
# ============================================================

# memory = in-process TTL map (default, single-instance only, resets on restart)
# redis  = Upstash Redis (survives restarts, works across multiple instances)
CACHE_BACKEND=memory

# Required only when CACHE_BACKEND=redis.
# Get from: Upstash console → Database → REST API
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<your-upstash-rest-token>  ← store as 🔒 Secret


# ============================================================
# BACKGROUND JOB QUEUE — BullMQ  (🔒 Secret)
# ============================================================

# Direct TCP Redis URL for BullMQ (ioredis).
# MUST be a TCP URL (rediss://...) — Upstash REST URLs do NOT work here.
# Without this, the Worker Server skips cleanly and jobs run inline.
# REDIS_URL=rediss://default:PASSWORD@host:PORT


# ============================================================
# SECURITY — ENCRYPTION  (🔒 Secret)
# ============================================================

# 32-byte base64 AES-256-GCM key for encrypting PII fields at rest
# (address, bio, notes, totpSecret, backupCodes).
# Auto-generated at first boot and saved in DB.
# SET THIS EXPLICITLY IN PRODUCTION — changing the key renders all
# encrypted data in the database permanently unreadable.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ENCRYPTION_KEY=


# ============================================================
# SECURITY — JWT  (🔒 Secret)
# ============================================================

# Signing secret for internal JWT tokens.
# Auto-generated at first boot and saved in DB.
# Set explicitly in production for stability across re-deploys.
# JWT_SECRET=


# ============================================================
# CORS
# ============================================================

# Extra allowed origins (comma-separated URLs).
# Replit dev + deployed domains are auto-added since v4.9.0.
# Only needed for custom (non-Replit) domains.
# CORS_ORIGIN=https://yourdomain.com,https://api.yourdomain.com


# ============================================================
# SEED DATA DEFAULTS (used only by Seed Database workflow)
# ============================================================

# Email for the seeded admin account. Falls back to SMTP_USER.
# ADMIN_EMAIL=admin@example.com

# Mobile number for the seeded admin account.
ADMIN_MOBILE=9876543210

# Email for the seeded operator account.
OPERATOR_EMAIL=operator@sahucsc.in

# Mobile number for the seeded operator account.
OPERATOR_MOBILE=9876543211

# Business name shown on receipts, PDF exports, and email footers.
BUSINESS_NAME=SAHU CSC Center

# Business address shown on receipts and PDF exports.
BUSINESS_ADDRESS=Main Road, Bargarh, Odisha 768028

# Business contact mobile shown on public receipt pages.
# Falls back to ADMIN_MOBILE if not set.
# BUSINESS_MOBILE=9876543210


# ============================================================
# GeoIP — MAXMIND  (🔒 Secret)
# ============================================================

# MaxMind license key for weekly GeoIP database refresh (every Sunday 03:00).
# Without it, geo-blocking works off the bundled snapshot (may be months old).
# Get a free key at: https://www.maxmind.com/en/geolite2/signup
# MAXMIND_LICENSE_KEY=


# ============================================================
# OBSERVABILITY — SENTRY  (🔒 Secrets)
# ============================================================

# Server-side Sentry DSN (API process).
# Get from: sentry.io → Project → Settings → Client Keys
# SENTRY_DSN=https://xxx@oxx.ingest.sentry.io/project-id

# Fraction of requests to trace (0.0–1.0). Requires SENTRY_DSN.
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Client-side Sentry DSN (React frontend — baked in at build time).
# VITE_SENTRY_DSN=https://xxx@oxx.ingest.sentry.io/project-id


# ============================================================
# FEATURE FLAGS
# ============================================================

# Set to true to bypass the India-only GeoIP block.
# Useful when testing from outside India or behind a non-Indian VPN.
# ALLOW_NON_INDIA=false


# ============================================================
# LOGGING & PERFORMANCE
# ============================================================

# Pino log level: trace | debug | info | warn | error
# Default: info. Never use trace in production (logs request bodies).
# LOG_LEVEL=info

# Warn threshold in milliseconds for slow API requests.
# Default: 500
# SLOW_REQUEST_MS=500


# ============================================================
# RUNTIME-MANAGED — DO NOT SET MANUALLY
# Replit injects these automatically. Setting them causes conflicts.
# ============================================================
#
# DATABASE_URL      — Replit-managed PostgreSQL (fallback for NEON_DATABASE_URL)
# PGDATABASE        — database name
# PGHOST            — database hostname
# PGPORT            — database port
# PGUSER            — database user
# PGPASSWORD        — database password
# REPLIT_DEV_DOMAIN — current dev preview domain (auto-added to CORS)
# REPLIT_DOMAINS    — all domains for this repl (auto-added to CORS)
# REPL_ID           — unique repl identifier
